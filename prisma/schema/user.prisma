model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(256)
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    createdAt    DateTime     @default(now())
    updated      DateTime     @updatedAt
    profileId    Profile?

    @@map("Users")
}
